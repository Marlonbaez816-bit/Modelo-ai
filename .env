# ============================================================
# ATHENA CORE — Variables de entorno
# Copia este archivo como ".env" y ajusta los valores a tu
# entorno real. Vite solo expone al cliente las variables que
# empiezan con el prefijo VITE_.
# ============================================================

# URL base de TU sistema (Athena Core / motor semántico).
# La interfaz llamará a esta URL para enviar mensajes y
# verificar el estado de conexión. Sin protocolo final "/".
VITE_SYSTEM_API_URL=http://localhost:3000

# Nombre visible de la aplicación (usado en la barra lateral y el título).
VITE_APP_NAME=Athena Core

# Tiempo máximo de espera (ms) antes de considerar que una
# petición a tu sistema se agotó (timeout).
VITE_SYSTEM_TIMEOUT_MS=30000